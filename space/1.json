{
  "title": "SVG 圆角饼图",
  "sections": [
    {
      "name": "svg polar chart",
      "description": "svg 圆角饼图基础",
      "showHTML": true,
      "showCSS": false,
      "showJS": false,
      "html": [
        { "indent": "0", "value": "<svg" },
        { "indent": "2", "value": "width='320'" },
        { "indent": "2", "value": "id='polarChart'" },
        { "indent": "2", "value": "xmlns='http://www.w3.org/2000/svg'" },
        { "indent": "2", "value": "viewBox='-100 -100 200 200'" },
        { "indent": "0", "value": "></svg>" }
      ],
      "css": [
        { "indent": "0", "value": "body {" },
        { "indent": "2", "value": "display: flex;" },
        { "indent": "2", "value": "justify-content: center;" },
        { "indent": "2", "value": "align-items: center;" },
        { "indent": "0", "value": "}" },
        { "indent": "0", "value": "svg {" },
        { "indent": "2", "value": "margin: auto;" },
        { "indent": "2", "value": "border: 1px solid #000;" },
        { "indent": "0", "value": "}" }
      ],
      "js": [
        { "indent": "0", "value": "function generatePolarChart(config) {" },
        { "indent": "2", "value": "function toPI(degrees) {" },
        { "indent": "4", "value": "return degrees * (Math.PI / 180);" },
        { "indent": "2", "value": "}" },
        { "indent": "0", "value": "" },
        {
          "indent": "2",
          "value": "function coordinate(firstAngle, changeAngle, offsetAngle, R, r) {"
        },
        {
          "indent": "4",
          "value": "const x1 = Math.cos(toPI(firstAngle)) * (R - r);"
        },
        {
          "indent": "4",
          "value": "const y1 = Math.sin(toPI(firstAngle)) * (R - r);"
        },
        {
          "indent": "4",
          "value": "const x2 = Math.cos(toPI(firstAngle + offsetAngle)) * R;"
        },
        {
          "indent": "4",
          "value": "const y2 = Math.sin(toPI(firstAngle + offsetAngle)) * R;"
        },
        {
          "indent": "4",
          "value": "const x3 = Math.cos(toPI(firstAngle + changeAngle - offsetAngle)) * R;"
        },
        {
          "indent": "4",
          "value": "const y3 = Math.sin(toPI(firstAngle + changeAngle - offsetAngle)) * R;"
        },
        {
          "indent": "4",
          "value": "const x4 = Math.cos(toPI(firstAngle + changeAngle)) * (R - r);"
        },
        {
          "indent": "4",
          "value": "const y4 = Math.sin(toPI(firstAngle + changeAngle)) * (R - r);"
        },
        {
          "indent": "4",
          "value": "return { x1, y1, x2, y2, x3, y3, x4, y4 };"
        },
        { "indent": "2", "value": "}" },
        { "indent": "0", "value": "" },
        {
          "indent": "2",
          "value": "const { fill, stroke, strokeWidth, R, r, rotate, values } = config;"
        },
        { "indent": "0", "value": "" },
        {
          "indent": "2",
          "value": "const svgNS = 'http://www.w3.org/2000/svg';"
        },
        {
          "indent": "2",
          "value": "const path = document.createElementNS(svgNS, 'path');"
        },
        { "indent": "2", "value": "path.setAttribute('fill', fill);" },
        { "indent": "2", "value": "path.setAttribute('stroke', stroke);" },
        {
          "indent": "2",
          "value": "path.setAttribute('stroke-width', strokeWidth);"
        },
        { "indent": "0", "value": "" },
        {
          "indent": "2",
          "value": "const totalValue = values.reduce((sum, val) => sum + val, 0);"
        },
        {
          "indent": "2",
          "value": "const changeAngles = values.map((val) => (val / totalValue) * 360);"
        },
        { "indent": "0", "value": "" },
        { "indent": "2", "value": "let d = 'M0 0 ';" },
        { "indent": "2", "value": "let firstAngle = rotate;" },
        {
          "indent": "2",
          "value": "const offsetAngle = Math.atan(r / (R - r)) * (180 / Math.PI);"
        },
        { "indent": "0", "value": "" },
        { "indent": "2", "value": "changeAngles.forEach((changeAngle) => {" },
        {
          "indent": "4",
          "value": "const { x1, y1, x2, y2, x3, y3, x4, y4 } = coordinate("
        },
        { "indent": "6", "value": "firstAngle," },
        { "indent": "6", "value": "changeAngle," },
        { "indent": "6", "value": "offsetAngle," },
        { "indent": "6", "value": "R," },
        { "indent": "6", "value": "r" },
        { "indent": "4", "value": ");" },
        { "indent": "0", "value": "" },
        { "indent": "4", "value": "const flag = changeAngle > 180 ? 1 : 0;" },
        { "indent": "0", "value": "" },
        { "indent": "4", "value": "d += `L${x1} ${y1} `;" },
        { "indent": "4", "value": "d += `A${r} ${r} 0 0 1 ${x2} ${y2} `;" },
        {
          "indent": "4",
          "value": "d += `A${R} ${R} 0 ${flag} 1 ${x3} ${y3} `;"
        },
        { "indent": "4", "value": "d += `A${r} ${r} 0 0 1 ${x4} ${y4} `;" },
        { "indent": "4", "value": "d += 'Z ';" },
        { "indent": "0", "value": "" },
        { "indent": "4", "value": "firstAngle += changeAngle;" },
        { "indent": "2", "value": "});" },
        { "indent": "0", "value": "" },
        { "indent": "2", "value": "path.setAttribute('d', d);" },
        {
          "indent": "2",
          "value": "document.getElementById('polarChart').appendChild(path);"
        },
        { "indent": "0", "value": "}" },
        { "indent": "0", "value": "" },
        { "indent": "0", "value": "const config = {" },
        { "indent": "2", "value": "fill: '#0cf5'," },
        { "indent": "2", "value": "stroke: '#fff'," },
        { "indent": "2", "value": "strokeWidth: '1'," },
        { "indent": "2", "value": "R: 60," },
        { "indent": "2", "value": "r: 5," },
        { "indent": "2", "value": "rotate: 70," },
        { "indent": "2", "value": "values: [50, 75, 44, 55, 100, 50, 75]," },
        { "indent": "0", "value": "};" },
        { "indent": "0", "value": "" },
        { "indent": "0", "value": "generatePolarChart(config);" }
      ]
    },
    {
      "name": "svg polar chart with data",
      "description": "svg 圆角饼图带有数据和折线",
      "showHTML": true,
      "showCSS": false,
      "showJS": false,
      "html": [
        { "indent": "0", "value": "<svg" },
        { "indent": "2", "value": "width='320'" },
        { "indent": "2", "value": "id='polarChart2'" },
        { "indent": "2", "value": "xmlns='http://www.w3.org/2000/svg'" },
        { "indent": "2", "value": "viewBox='-100 -100 200 200'" },
        { "indent": "0", "value": "></svg>" }
      ],
      "css": [
        { "indent": "0", "value": "body {" },
        { "indent": "2", "value": "display: flex;" },
        { "indent": "2", "value": "justify-content: center;" },
        { "indent": "2", "value": "align-items: center;" },
        { "indent": "0", "value": "}" },
        { "indent": "0", "value": "svg {" },
        { "indent": "2", "value": "margin: auto;" },
        { "indent": "2", "value": "border: 1px solid #000;" },
        { "indent": "0", "value": "}" }
      ],
      "js": [
        {
          "indent": "0",
          "value": "const svgNS = 'http://www.w3.org/2000/svg';"
        },
        { "indent": "0", "value": "let coordinates = [];" },
        { "indent": "0", "value": "" },
        { "indent": "0", "value": "function toPI(degrees) {" },
        { "indent": "2", "value": "return degrees * (Math.PI / 180);" },
        { "indent": "0", "value": "}" },
        { "indent": "0", "value": "" },
        {
          "indent": "0",
          "value": "function coordinate(firstAngle, changeAngle, offsetAngle, R, r, dis) {"
        },
        {
          "indent": "2",
          "value": "const x1 = Math.cos(toPI(firstAngle)) * (R - r);"
        },
        {
          "indent": "2",
          "value": "const y1 = Math.sin(toPI(firstAngle)) * (R - r);"
        },
        {
          "indent": "2",
          "value": "const x2 = Math.cos(toPI(firstAngle + offsetAngle)) * R;"
        },
        {
          "indent": "2",
          "value": "const y2 = Math.sin(toPI(firstAngle + offsetAngle)) * R;"
        },
        {
          "indent": "2",
          "value": "const x3 = Math.cos(toPI(firstAngle + changeAngle - offsetAngle)) * R;"
        },
        {
          "indent": "2",
          "value": "const y3 = Math.sin(toPI(firstAngle + changeAngle - offsetAngle)) * R;"
        },
        {
          "indent": "2",
          "value": "const x4 = Math.cos(toPI(firstAngle + changeAngle)) * (R - r);"
        },
        {
          "indent": "2",
          "value": "const y4 = Math.sin(toPI(firstAngle + changeAngle)) * (R - r);"
        },
        {
          "indent": "2",
          "value": "const x5 = Math.cos(toPI(firstAngle + changeAngle / 2)) * (R + dis);"
        },
        {
          "indent": "2",
          "value": "const y5 = Math.sin(toPI(firstAngle + changeAngle / 2)) * (R + dis);"
        },
        {
          "indent": "2",
          "value": "return { x1, y1, x2, y2, x3, y3, x4, y4, x5, y5 };"
        },
        { "indent": "0", "value": "}" },
        { "indent": "0", "value": "" },
        { "indent": "0", "value": "function generatePolarChart(config) {" },
        {
          "indent": "2",
          "value": "const { fill, stroke, strokeWidth, R, r, dis, rotate, values } = config;"
        },
        {
          "indent": "2",
          "value": "const path = document.createElementNS(svgNS, 'path');"
        },
        { "indent": "2", "value": "path.setAttribute('stroke', stroke);" },
        {
          "indent": "2",
          "value": "path.setAttribute('stroke-width', strokeWidth);"
        },
        {
          "indent": "2",
          "value": "const totalValue = values.reduce((sum, val) => sum + val, 0);"
        },
        {
          "indent": "2",
          "value": "const changeAngles = values.map((val) => (val / totalValue) * 360);"
        },
        { "indent": "2", "value": "let firstAngle = rotate;" },
        {
          "indent": "2",
          "value": "const offsetAngle = Math.atan(r / (R - r)) * (180 / Math.PI);"
        },
        { "indent": "2", "value": "coordinates = [];" },
        {
          "indent": "2",
          "value": "changeAngles.forEach((changeAngle, index) => {"
        },
        {
          "indent": "4",
          "value": "const { x1, y1, x2, y2, x3, y3, x4, y4, x5, y5 } = coordinate("
        },
        { "indent": "6", "value": "firstAngle," },
        { "indent": "6", "value": "changeAngle," },
        { "indent": "6", "value": "offsetAngle," },
        { "indent": "6", "value": "R," },
        { "indent": "6", "value": "r," },
        { "indent": "6", "value": "dis" },
        { "indent": "4", "value": ");" },
        { "indent": "4", "value": "coordinates.push({ x5, y5 });" },
        { "indent": "4", "value": "const flag = changeAngle > 180 ? 1 : 0;" },
        { "indent": "4", "value": "let d = `M0 0 L${x1} ${y1} `;" },
        { "indent": "4", "value": "d += `A${r} ${r} 0 0 1 ${x2} ${y2} `;" },
        {
          "indent": "4",
          "value": "d += `A${R} ${R} 0 ${flag} 1 ${x3} ${y3} `;"
        },
        { "indent": "4", "value": "d += `A${r} ${r} 0 0 1 ${x4} ${y4} Z`;" },
        {
          "indent": "4",
          "value": "const segment = document.createElementNS(svgNS, 'path');"
        },
        { "indent": "4", "value": "segment.setAttribute('d', d);" },
        {
          "indent": "4",
          "value": "segment.setAttribute('fill', fill[index]);"
        },
        { "indent": "4", "value": "segment.setAttribute('stroke', stroke);" },
        {
          "indent": "4",
          "value": "segment.setAttribute('stroke-width', strokeWidth);"
        },
        {
          "indent": "4",
          "value": "document.getElementById('polarChart2').appendChild(segment);"
        },
        { "indent": "4", "value": "firstAngle += changeAngle;" },
        { "indent": "2", "value": "});" },
        { "indent": "0", "value": "}" },
        { "indent": "0", "value": "" },
        { "indent": "0", "value": "function generatePolarLines(config) {" },
        { "indent": "2", "value": "const { stroke, strokeWidth } = config;" },
        {
          "indent": "2",
          "value": "coordinates.forEach(({ x5, y5 }, index) => {"
        },
        { "indent": "4", "value": "const dx = x5 > 0 ? 20 : -20;" },
        {
          "indent": "4",
          "value": "const path = document.createElementNS(svgNS, 'path');"
        },
        { "indent": "4", "value": "path.setAttribute('fill', 'none');" },
        {
          "indent": "4",
          "value": "path.setAttribute('stroke', stroke[index]);"
        },
        {
          "indent": "4",
          "value": "path.setAttribute('stroke-width', strokeWidth);"
        },
        {
          "indent": "4",
          "value": "path.setAttribute('d', `M${x5 / 1.2} ${y5 / 1.2} L${x5} ${y5} h${dx}`);"
        },
        {
          "indent": "4",
          "value": "document.getElementById('polarChart2').appendChild(path);"
        },
        { "indent": "2", "value": "});" },
        { "indent": "0", "value": "}" },
        { "indent": "0", "value": "" },
        { "indent": "0", "value": "function generatePolarText(config) {" },
        {
          "indent": "2",
          "value": "const { fontSize, fill, content } = config;"
        },
        { "indent": "2", "value": "content.forEach((text, index) => {" },
        { "indent": "4", "value": "const { x5, y5 } = coordinates[index];" },
        { "indent": "4", "value": "console.log(x5, y5);" },
        { "indent": "4", "value": "const dx = x5 > 0 ? 20 : -20;" },
        {
          "indent": "4",
          "value": "const textElem = document.createElementNS(svgNS, 'text');"
        },
        { "indent": "4", "value": "textElem.setAttribute('x', x5 + dx);" },
        { "indent": "4", "value": "textElem.setAttribute('y', y5);" },
        {
          "indent": "4",
          "value": "textElem.setAttribute('font-size', fontSize);"
        },
        {
          "indent": "4",
          "value": "textElem.setAttribute('text-anchor', x5 >= 0 ? 'end' : 'start');"
        },
        {
          "indent": "4",
          "value": "textElem.setAttribute('alignment-baseline', 'after-edge');"
        },
        {
          "indent": "4",
          "value": "textElem.setAttribute('fill', fill[index]);"
        },
        { "indent": "4", "value": "textElem.textContent = text;" },
        {
          "indent": "4",
          "value": "document.getElementById('polarChart2').appendChild(textElem);"
        },
        { "indent": "2", "value": "});" },
        { "indent": "0", "value": "}" },
        { "indent": "0", "value": "" },
        { "indent": "0", "value": "const config = {" },
        { "indent": "2", "value": "chart: {" },
        {
          "indent": "4",
          "value": "fill: ['#0ff', '#0f4', '#f88', '#f00', '#f8f', '#05f'],"
        },
        { "indent": "4", "value": "stroke: '#eee'," },
        { "indent": "4", "value": "strokeWidth: '2'," },
        { "indent": "4", "value": "R: 60," },
        { "indent": "4", "value": "r: 5," },
        { "indent": "4", "value": "dis: 10," },
        { "indent": "4", "value": "rotate: 0," },
        { "indent": "4", "value": "values: [60, 60, 80, 40, 50, 70]," },
        { "indent": "2", "value": "}," },
        { "indent": "2", "value": "lines: {" },
        {
          "indent": "4",
          "value": "stroke: ['#0ff', '#0f4', '#f88', '#f00', '#f8f', '#05f'],"
        },
        { "indent": "4", "value": "strokeWidth: '1'," },
        { "indent": "2", "value": "}," },
        { "indent": "2", "value": "text: {" },
        { "indent": "4", "value": "fontSize: '7'," },
        {
          "indent": "4",
          "value": "fill: ['#0ff', '#0f4', '#f88', '#f00', '#f8f', '#05f'],"
        },
        {
          "indent": "4",
          "value": "content: ['HTML', 'CSS', 'JS', 'RECT', 'VUE', 'JQUERY'],"
        },
        { "indent": "2", "value": "}," },
        { "indent": "0", "value": "};" },
        { "indent": "0", "value": "" },
        { "indent": "0", "value": "generatePolarChart(config.chart);" },
        { "indent": "0", "value": "generatePolarLines(config.lines);" },
        { "indent": "0", "value": "generatePolarText(config.text);" }
      ]
    }
  ]
}
